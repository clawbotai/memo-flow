# Qwen API 配置
# 获取地址：https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-api-key-here

# DeepSeek API 配置（备用）
# 获取地址：https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=your-deepseek-api-key

# 可选配置
